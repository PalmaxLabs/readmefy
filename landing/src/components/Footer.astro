---
import { Github, Twitter, ArrowUpRight } from 'lucide-astro';
---

<footer class="footer-module__Vmx-gq__footer dr-layout-grid reveal">
	<div class="footer-module__Vmx-gq__top">
		<div class="footer-module__Vmx-gq__first-line">
			<h2 style="font-family: var(--font-panchang); font-size: 8vw; line-height: 1; font-weight: 800; text-transform: uppercase;">
				READMEFY
			</h2>
		</div>
		
		<div class="footer-module__Vmx-gq__shameless-plug">
			<p class="p-s" style="font-weight: 900; text-transform: uppercase;">Built by Palmax Labs</p>
			<p class="p-s" style="opacity: 0.6;">© 2026 READMEFY — ALL RIGHTS RESERVED</p>
		</div>

		<div class="footer-module__Vmx-gq__cta">
			<a href="https://github.com/kevin/readmefy" class="button-module__h0EWEW__button" style="width: fit-content; min-width: 20vw;">
				<span class="button-module__h0EWEW__icon">
					<Github size={24} />
				</span>
				<span class="button-module__h0EWEW__text">
					<span class="button-module__h0EWEW__visible">CONTRIBUTE</span>
					<span class="button-module__h0EWEW__hidden">GITHUB <ArrowUpRight size={16} class="button-module__h0EWEW__arrow" /></span>
				</span>
			</a>
		</div>

		<div class="footer-module__Vmx-gq__last-line">
			<p class="p-s" style="font-family: var(--font-panchang); font-size: 1.5vw; opacity: 0.4;">
				DOCUMENTATION MADE SIMPLE.
			</p>
		</div>
	</div>

	<div class="footer-module__Vmx-gq__bottom">
		<div class="footer-module__Vmx-gq__links">
			<a href="#" class="footer-module__Vmx-gq__link p-s">PRODUCT</a>
			<a href="#" class="footer-module__Vmx-gq__link p-s">SHOWCASE</a>
			<a href="#" class="footer-module__Vmx-gq__link p-s">RELEASES</a>
			<a href="#" class="footer-module__Vmx-gq__link p-s">SECURITY</a>
		</div>
		
		<div class="footer-module__Vmx-gq__tm">
			<p class="p-s">Designed with <span>♥</span> in Palmax</p>
		</div>
	</div>
</footer>

<style>
	.footer-module__Vmx-gq__footer {
		height: 100vh;
		padding: var(--safe) 0;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		display: flex;
		flex-direction: column;
		justify-content: space-between;
	}

	.footer-module__Vmx-gq__top {
		grid-column: 1 / -1;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		height: 70%;
	}

	.footer-module__Vmx-gq__bottom {
		grid-column: 1 / -1;
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		padding-top: 2rem;
	}

	.footer-module__Vmx-gq__links {
		display: flex;
		gap: 2rem;
	}

	.footer-module__Vmx-gq__link {
		text-decoration: none;
		color: var(--color-white);
		font-weight: 700;
		font-family: var(--font-roboto);
		text-transform: uppercase;
		font-size: 0.8rem;
		opacity: 0.5;
		transition: opacity 0.3s var(--ease);
	}

	.footer-module__Vmx-gq__link:hover {
		opacity: 1;
	}

	.footer-module__Vmx-gq__cta {
		margin-top: 4rem;
	}

	@media (max-width: 800px) {
		.footer-module__Vmx-gq__footer {
			height: auto;
			padding: 5rem var(--safe);
		}
		
		.footer-module__Vmx-gq__links {
			flex-direction: column;
			gap: 1rem;
		}
		
		.footer-module__Vmx-gq__bottom {
			flex-direction: column;
			align-items: flex-start;
			gap: 3rem;
		}
	}
</style>

